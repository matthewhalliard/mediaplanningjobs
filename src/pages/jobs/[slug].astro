---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const jobs = await getCollection("jobs");
  return jobs.map((job) => ({ params: { slug: job.slug }, props: { job } }));
}

interface Props { job: CollectionEntry<"jobs">; }
const { job } = Astro.props;
const { Content } = await job.render();
const d = job.data;

// Convert raw MDX body to a sanitized HTML string for JSON-LD `description`.
// Google Jobs needs substantive description text — not just one line.
// We strip MDX-specific syntax and wrap paragraphs in <p>. Headings become <h3>,
// list items become <li>. Output is HTML-encoded for the JSON-LD field.
const toJsonLdHtml = (raw: string): string => {
  // Drop frontmatter (already gone from .body but defensive).
  const body = raw.replace(/^---[\s\S]*?---\s*/m, "").trim();
  if (!body) return `<p>${d.title} at ${d.company}, based in ${d.location}.</p>`;
  const lines = body.split(/\n/);
  const out: string[] = [];
  let inList = false;
  let para: string[] = [];
  const flushPara = () => {
    if (para.length) {
      out.push(`<p>${para.join(" ").trim()}</p>`);
      para = [];
    }
  };
  const closeList = () => {
    if (inList) {
      out.push("</ul>");
      inList = false;
    }
  };
  for (const ln of lines) {
    const t = ln.trim();
    if (!t) {
      flushPara();
      closeList();
      continue;
    }
    const h = t.match(/^(#{1,6})\s+(.+)$/);
    if (h) {
      flushPara();
      closeList();
      out.push(`<h3>${h[2]}</h3>`);
      continue;
    }
    const li = t.match(/^[-*]\s+(.+)$/);
    if (li) {
      flushPara();
      if (!inList) {
        out.push("<ul>");
        inList = true;
      }
      out.push(`<li>${li[1]}</li>`);
      continue;
    }
    para.push(t);
  }
  flushPara();
  closeList();
  // Strip residual markdown emphasis/links — keep plain text inside tags.
  return out
    .join("")
    .replace(/\*\*(.+?)\*\*/g, "$1")
    .replace(/\*(.+?)\*/g, "$1")
    .replace(/\[(.+?)\]\([^)]+\)/g, "$1");
};
const descriptionHtml = toJsonLdHtml(job.body || "");

const fmtSalary = (min?: number, max?: number) => {
  if (!min && !max) return null;
  const fmt = (n: number) => `$${(n / 1000).toFixed(0)}K`;
  if (min && max) return `${fmt(min)} – ${fmt(max)}`;
  if (min) return `${fmt(min)}+`;
  return fmt(max!);
};
const salary = fmtSalary(d.salaryMin, d.salaryMax);

// Google JobPosting schema — required for Google Jobs eligibility.
const jsonLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "JobPosting",
  title: d.title,
  description: descriptionHtml,
  identifier: {
    "@type": "PropertyValue",
    name: "Media Planning Jobs",
    value: job.slug,
  },
  datePosted: d.postedAt.toISOString(),
  validThrough: new Date(d.postedAt.getTime() + 60 * 86400000).toISOString(),
  employmentType: d.employmentType,
  hiringOrganization: {
    "@type": "Organization",
    name: d.company,
    sameAs: d.companyUrl,
  },
  directApply: false,
  url: new URL(Astro.url.pathname, Astro.site).toString(),
};

// Location handling for Google JobPosting schema.
// Adzuna feed gives us "City, County" (not state). We:
//   - Treat country-only or comma-less locations as nationwide remote (TELECOMMUTE),
//     which lets us omit jobLocation entirely (Google-compliant).
//   - Drop addressRegion when it's a county name (schema.org expects a state/region,
//     not a county; emitting a county here is invalid data).
const locParts = d.location.split(",").map((s) => s.trim()).filter(Boolean);
const isNationwide =
  locParts.length < 2 || /^(US|USA|United States|Remote)$/i.test(d.location);
if (isNationwide || d.remote === "remote") {
  jsonLd.jobLocationType = "TELECOMMUTE";
  jsonLd.applicantLocationRequirements = {
    "@type": "Country",
    name: "US",
  };
}
if (!isNationwide) {
  const locality = locParts[0];
  const regionRaw = locParts[1];
  const region =
    regionRaw && !/county$/i.test(regionRaw) ? regionRaw : undefined;
  const address: Record<string, string> = {
    "@type": "PostalAddress",
    addressLocality: locality,
    addressCountry: "US",
  };
  if (region) address.addressRegion = region;
  jsonLd.jobLocation = {
    "@type": "Place",
    address,
  };
}
if (d.salaryMin || d.salaryMax) {
  jsonLd.baseSalary = {
    "@type": "MonetaryAmount",
    currency: "USD",
    value: {
      "@type": "QuantitativeValue",
      minValue: d.salaryMin,
      maxValue: d.salaryMax,
      unitText: "YEAR",
    },
  };
}
---
<BaseLayout
  title={`${d.title} at ${d.company} — ${d.location}`}
  description={`${d.title} role at ${d.company}, ${d.location}. Apply now on Media Planning Jobs.`}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-3xl px-6 py-12">
    <a href="/jobs" class="text-sm text-ink-500 hover:text-ink-800">← All jobs</a>
    <header class="mt-4 border-b border-ink-100 pb-6">
      <h1 class="text-3xl font-semibold text-ink-900">{d.title}</h1>
      <p class="mt-2 text-lg text-ink-700">
        <span class="font-medium">{d.company}</span>
        <span class="mx-2 text-ink-300">·</span>
        <span>{d.location}</span>
        {d.remote !== "onsite" && (
          <>
            <span class="mx-2 text-ink-300">·</span>
            <span class="capitalize">{d.remote}</span>
          </>
        )}
      </p>
      <div class="mt-3 flex flex-wrap gap-2 text-sm">
        <span class="rounded bg-ink-100 px-2 py-1 text-ink-700 capitalize">{d.function}</span>
        <span class="rounded bg-ink-100 px-2 py-1 text-ink-700 capitalize">{d.level}</span>
        {salary && <span class="rounded bg-brand/10 px-2 py-1 font-medium text-brand">{salary}</span>}
      </div>
      <div class="mt-6 flex items-center gap-3">
        <a
          href={d.applyUrl}
          target="_blank"
          rel="noopener nofollow"
          class="rounded-md bg-brand px-5 py-2.5 font-medium text-white hover:bg-brand-dark"
        >
          Apply now ↗
        </a>
        <span class="text-sm text-ink-500">
          Posted {d.postedAt.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
        </span>
      </div>
    </header>
    <div class="prose prose-ink mt-6 max-w-none text-ink-700">
      <Content />
    </div>
    <div class="mt-10 rounded-lg border border-ink-100 bg-ink-50 p-5 text-sm text-ink-600">
      Listing aggregated from {d.source ?? "public sources"}. Apply directly on the employer's site.
    </div>
  </article>
</BaseLayout>
