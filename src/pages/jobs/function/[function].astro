---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import JobCard from "../../../components/JobCard.astro";
import { FUNCTION_INTROS, type FunctionIntro } from "../../../data/functionIntros";

export async function getStaticPaths() {
  return FUNCTION_INTROS.map((intro) => ({
    params: { function: intro.urlSlug },
    props: { intro },
  }));
}

interface Props {
  intro: FunctionIntro;
}
const { intro } = Astro.props;

const allJobs = (await getCollection("jobs"))
  .filter((j) => j.data.function === intro.slug)
  .sort((a, b) => b.data.postedAt.getTime() - a.data.postedAt.getTime());

const fmtSalary = (n: number) => `$${(n / 1000).toFixed(0)}K`;
const salaryRange = `${fmtSalary(intro.salaryBand.min)}–${fmtSalary(intro.salaryBand.max)}`;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

// Combined JSON-LD graph: FAQPage + CollectionPage + BreadcrumbList.
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "CollectionPage",
      "@id": canonical,
      url: canonical,
      name: intro.h1,
      description: intro.metaDescription,
      numberOfItems: allJobs.length,
    },
    {
      "@type": "FAQPage",
      mainEntity: intro.faqs.map((f) => ({
        "@type": "Question",
        name: f.q,
        acceptedAnswer: {
          "@type": "Answer",
          text: f.a,
        },
      })),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: new URL("/", Astro.site).toString(),
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Jobs",
          item: new URL("/jobs/", Astro.site).toString(),
        },
        {
          "@type": "ListItem",
          position: 3,
          name: intro.h1,
          item: canonical,
        },
      ],
    },
  ],
};
---
<BaseLayout
  title={intro.metaTitle}
  description={intro.metaDescription}
  canonical={canonical}
  jsonLd={jsonLd}
>
  <section class="mx-auto max-w-4xl px-6 py-10">
    <nav class="text-sm text-ink-500" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink-900">Home</a>
      <span class="mx-1.5">/</span>
      <a href="/jobs/" class="hover:text-ink-900">Jobs</a>
      <span class="mx-1.5">/</span>
      <span class="text-ink-700">{intro.label}</span>
    </nav>

    <h1 class="mt-3 text-3xl font-semibold text-ink-900 sm:text-4xl">{intro.h1}</h1>
    <p class="mt-2 text-ink-600">
      {allJobs.length} open {intro.label.toLowerCase()} {allJobs.length === 1 ? "role" : "roles"} ·
      Typical salary <span class="font-medium text-ink-900">{salaryRange}</span>
    </p>

    <div class="mt-6 space-y-4 text-base leading-relaxed text-ink-700">
      {intro.intro.map((p) => <p>{p}</p>)}
    </div>
  </section>

  <section class="mx-auto max-w-4xl px-6 pb-6">
    <h2 class="text-xl font-semibold text-ink-900">Open {intro.label} Roles</h2>
    {allJobs.length === 0 ? (
      <p class="mt-3 text-ink-600">
        No open {intro.label.toLowerCase()} roles right now. New listings post daily —
        <a href="/jobs/" class="text-brand underline">browse all jobs</a> or check back tomorrow.
      </p>
    ) : (
      <div class="mt-4 grid gap-3">
        {allJobs.map((j) => (
          <JobCard
            href={`/jobs/${j.slug}/`}
            title={j.data.title}
            company={j.data.company}
            location={j.data.location}
            remote={j.data.remote}
            func={j.data.function}
            level={j.data.level}
            salaryMin={j.data.salaryMin}
            salaryMax={j.data.salaryMax}
            postedAt={j.data.postedAt}
            featured={j.data.featured}
          />
        ))}
      </div>
    )}
  </section>

  <section class="mx-auto max-w-4xl px-6 pb-6">
    <h2 class="text-xl font-semibold text-ink-900">Top employers hiring {intro.label.toLowerCase()}</h2>
    <ul class="mt-3 flex flex-wrap gap-2 text-sm">
      {intro.topEmployers.map((e) => (
        <li class="rounded-md border border-ink-200 bg-white px-3 py-1.5 text-ink-700">{e}</li>
      ))}
    </ul>
  </section>

  <section class="mx-auto max-w-4xl px-6 pb-16">
    <h2 class="text-xl font-semibold text-ink-900">FAQs</h2>
    <div class="mt-4 space-y-5">
      {intro.faqs.map((f) => (
        <div>
          <h3 class="text-base font-medium text-ink-900">{f.q}</h3>
          <p class="mt-1 text-ink-700">{f.a}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
