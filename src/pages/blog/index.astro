---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Media Planning Jobs — Editorial",
  description:
    "Career guidance, salary data, and reporting on the media planning, buying, ad ops, and programmatic disciplines.",
  url: "https://getmediaplanningjobs.com/blog/",
  publisher: {
    "@type": "Organization",
    name: "Halliard",
    url: "https://halliardmedia.com",
  },
};
---
<BaseLayout
  title="Editorial — Career & Salary Guides for Media Professionals"
  description="Salary data, career path guides, and reporting on the media planning, buying, ad ops, and programmatic disciplines. Updated weekly."
  jsonLd={jsonLd}
>
  <section class="mx-auto max-w-4xl px-6 py-12">
    <h1 class="text-3xl font-semibold text-ink-900 sm:text-4xl">Editorial</h1>
    <p class="mt-2 text-ink-600">
      Career guides, salary data, and reporting for media professionals. New posts weekly.
      <a href="/feed.xml" class="text-brand hover:underline">RSS</a>.
    </p>

    {posts.length === 0 ? (
      <p class="mt-12 text-ink-600">No posts yet — first one ships next week.</p>
    ) : (
      <div class="mt-10 space-y-8">
        {posts.map((p) => (
          <article class="border-b border-ink-100 pb-8 last:border-0">
            <h2 class="text-xl font-semibold text-ink-900 sm:text-2xl">
              <a href={`/blog/${p.slug}/`} class="hover:text-brand">{p.data.title}</a>
            </h2>
            <p class="mt-2 text-ink-600">{p.data.description}</p>
            <p class="mt-3 text-sm text-ink-500">
              {p.data.author} · {fmtDate(p.data.publishedAt)}
              {p.data.readingMinutes && ` · ${p.data.readingMinutes} min read`}
            </p>
          </article>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
