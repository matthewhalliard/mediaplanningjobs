---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"posts">;
}
const { post } = Astro.props;
const { Content } = await post.render();
const d = post.data;

const fmtDate = (date: Date) =>
  date.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const SITE_ORG_ID = "https://getmediaplanningjobs.com/#organization";
const PUBLISHER_ID = "https://halliardmedia.com/#organization";

// Combined JSON-LD graph: Article + (FAQPage if present) + BreadcrumbList.
const graph: object[] = [
  {
    "@type": "Article",
    "@id": canonical,
    headline: d.title,
    description: d.description,
    inLanguage: "en-US",
    author: {
      "@type": "Organization",
      "@id": SITE_ORG_ID,
      name: d.author,
      url: "https://getmediaplanningjobs.com",
    },
    publisher: {
      "@type": "Organization",
      "@id": PUBLISHER_ID,
      name: "Halliard",
      url: "https://halliardmedia.com",
      logo: {
        "@type": "ImageObject",
        url: "https://getmediaplanningjobs.com/og-image.png",
      },
    },
    datePublished: d.publishedAt.toISOString(),
    dateModified: (d.updatedAt ?? d.publishedAt).toISOString(),
    mainEntityOfPage: canonical,
    image: "https://getmediaplanningjobs.com/og-image.png",
    keywords: [d.primaryKeyword, ...d.tags].join(", "),
  },
  {
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: new URL("/", Astro.site).toString(),
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Editorial",
        item: new URL("/blog/", Astro.site).toString(),
      },
      {
        "@type": "ListItem",
        position: 3,
        name: d.title,
        item: canonical,
      },
    ],
  },
];

if (d.faqs && d.faqs.length > 0) {
  graph.push({
    "@type": "FAQPage",
    mainEntity: d.faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: {
        "@type": "Answer",
        text: f.a,
      },
    })),
  });
}

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": graph,
};
---
<BaseLayout
  title={d.title}
  description={d.description}
  canonical={canonical}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-3xl px-6 py-10">
    <nav class="text-sm text-ink-500" aria-label="Breadcrumb">
      <a href="/" class="hover:text-ink-900">Home</a>
      <span class="mx-1.5">/</span>
      <a href="/blog/" class="hover:text-ink-900">Editorial</a>
      <span class="mx-1.5">/</span>
      <span class="text-ink-700">{d.title}</span>
    </nav>

    <header class="mt-4">
      <h1 class="text-3xl font-semibold leading-tight text-ink-900 sm:text-4xl">{d.title}</h1>
      <p class="mt-3 text-sm text-ink-500">
        {d.author} · {fmtDate(d.publishedAt)}
        {d.readingMinutes && ` · ${d.readingMinutes} min read`}
        {d.updatedAt && d.updatedAt.getTime() !== d.publishedAt.getTime() && (
          ` · Updated ${fmtDate(d.updatedAt)}`
        )}
      </p>
    </header>

    <div class="article mt-8">
      <Content />
    </div>

    {d.faqs && d.faqs.length > 0 && (
      <section class="mt-12 border-t border-ink-100 pt-10">
        <h2 class="text-2xl font-semibold text-ink-900">FAQs</h2>
        <div class="mt-5 space-y-5">
          {d.faqs.map((f) => (
            <div>
              <h3 class="text-base font-medium text-ink-900">{f.q}</h3>
              <p class="mt-1 text-ink-700">{f.a}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    <footer class="mt-12 border-t border-ink-100 pt-8 text-sm text-ink-500">
      <p>
        Published by Halliard Editorial. Found this useful? Browse
        <a href="/jobs/" class="text-brand hover:underline">open media roles</a>
        or check
        <a href="/blog/" class="text-brand hover:underline">other career guides</a>.
      </p>
    </footer>
  </article>
</BaseLayout>

<style is:global>
  .article {
    color: rgb(45 45 52); /* ink-700 */
    font-size: 1.0625rem;
    line-height: 1.75;
  }
  .article > * + * { margin-top: 1.25em; }
  .article h2 {
    font-size: 1.5rem;
    font-weight: 600;
    color: rgb(14 14 17); /* ink-900 */
    margin-top: 2.25em;
    line-height: 1.3;
  }
  .article h3 {
    font-size: 1.2rem;
    font-weight: 600;
    color: rgb(14 14 17);
    margin-top: 1.75em;
    line-height: 1.35;
  }
  .article ul, .article ol { padding-left: 1.5rem; }
  .article ul { list-style: disc; }
  .article ol { list-style: decimal; }
  .article li + li { margin-top: 0.5em; }
  .article a {
    color: #0a7b6f;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .article a:hover { color: #075c54; }
  .article strong { color: rgb(14 14 17); font-weight: 600; }
  .article blockquote {
    border-left: 3px solid rgb(216 216 221); /* ink-200 */
    padding-left: 1rem;
    color: rgb(91 91 103); /* ink-500 */
    font-style: italic;
  }
  .article code {
    background: rgb(247 247 248); /* ink-50 */
    padding: 0.15em 0.35em;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }
  .article pre {
    background: rgb(29 29 34); /* ink-800 */
    color: rgb(238 238 240); /* ink-100 */
    padding: 1rem 1.25rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    font-size: 0.9em;
    line-height: 1.6;
  }
  .article pre code { background: transparent; padding: 0; }
  .article hr { border-top: 1px solid rgb(238 238 240); margin: 2.5em 0; }
</style>
