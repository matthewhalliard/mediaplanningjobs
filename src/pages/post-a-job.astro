---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Post a Job — Media Planning Jobs"
  description="Hire media planners, buyers, ad ops, and programmatic talent. Specialist board reaching the discipline directly."
>
  <section class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-3xl font-semibold text-ink-900">Post a job</h1>
    <p class="mt-3 text-lg text-ink-600">
      Reach media planners, buyers, ad ops, and programmatic professionals directly. No resume-spam, no irrelevant applicants.
    </p>

    <div class="mt-8 grid gap-6 sm:grid-cols-2">
      <div class="rounded-lg border border-ink-100 p-6">
        <h2 class="text-lg font-semibold text-ink-900">Standard listing</h2>
        <p class="mt-1 text-3xl font-semibold text-ink-900">$99</p>
        <p class="mt-1 text-sm text-ink-500">30 days</p>
        <ul class="mt-4 space-y-2 text-sm text-ink-700">
          <li>✓ Listed on the homepage and category pages</li>
          <li>✓ Indexed in Google for Jobs (JobPosting schema)</li>
          <li>✓ Included in the weekly newsletter</li>
        </ul>
      </div>
      <div class="rounded-lg border-2 border-brand/40 bg-brand/[0.03] p-6">
        <h2 class="text-lg font-semibold text-ink-900">Featured</h2>
        <p class="mt-1 text-3xl font-semibold text-ink-900">$299</p>
        <p class="mt-1 text-sm text-ink-500">30 days</p>
        <ul class="mt-4 space-y-2 text-sm text-ink-700">
          <li>✓ Pinned at the top of the homepage</li>
          <li>✓ Highlighted in the newsletter</li>
          <li>✓ Social post on launch</li>
          <li>✓ Everything in standard</li>
        </ul>
      </div>
    </div>

    <div class="mt-10 rounded-lg border border-ink-100 bg-ink-50 p-6 text-sm text-ink-700">
      <p class="font-medium text-ink-900">Want to post?</p>
      <p class="mt-1">
        Email <a href="mailto:jobs@mediaplanningjobs.io" class="text-brand hover:underline">jobs@mediaplanningjobs.io</a> with the role details and we'll get you live within 24 hours. Self-serve checkout coming soon.
      </p>
    </div>
  </section>
</BaseLayout>
