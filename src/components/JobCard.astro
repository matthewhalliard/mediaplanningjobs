---
interface Props {
  href: string;
  title: string;
  company: string;
  location: string;
  remote: "onsite" | "hybrid" | "remote";
  func: string;
  level: string;
  salaryMin?: number;
  salaryMax?: number;
  postedAt: Date;
  featured?: boolean;
}
const {
  href, title, company, location, remote, func, level,
  salaryMin, salaryMax, postedAt, featured,
} = Astro.props;
const fmtSalary = (min?: number, max?: number) => {
  if (!min && !max) return null;
  const fmt = (n: number) => `$${(n / 1000).toFixed(0)}K`;
  if (min && max) return `${fmt(min)} – ${fmt(max)}`;
  if (min) return `${fmt(min)}+`;
  return fmt(max!);
};
const salary = fmtSalary(salaryMin, salaryMax);
const days = Math.floor((Date.now() - postedAt.getTime()) / 86400000);
const ago = days === 0 ? "today" : days === 1 ? "1d ago" : `${days}d ago`;
const funcLabels: Record<string, string> = {
  planning: "Planning", buying: "Buying", "ad-ops": "Ad Ops",
  programmatic: "Programmatic", analytics: "Analytics",
  strategy: "Strategy", leadership: "Leadership",
};
---
<a
  href={href}
  class:list={[
    "block rounded-lg border p-5 transition hover:border-brand hover:shadow-sm",
    featured ? "border-brand/40 bg-brand/[0.03]" : "border-ink-100 bg-white",
  ]}
>
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-2">
        {featured && (
          <span class="rounded-full bg-brand/10 px-2 py-0.5 text-xs font-medium text-brand">
            Featured
          </span>
        )}
        <h3 class="truncate text-base font-semibold text-ink-900">{title}</h3>
      </div>
      <p class="mt-1 text-sm text-ink-600">
        <span class="font-medium text-ink-700">{company}</span>
        <span class="mx-2 text-ink-300">·</span>
        <span>{location}</span>
        {remote !== "onsite" && (
          <>
            <span class="mx-2 text-ink-300">·</span>
            <span class="capitalize">{remote}</span>
          </>
        )}
      </p>
    </div>
    <div class="flex shrink-0 flex-col items-end gap-1 text-xs text-ink-500">
      {salary && <span class="font-medium text-ink-700">{salary}</span>}
      <span>{ago}</span>
    </div>
  </div>
  <div class="mt-3 flex flex-wrap gap-2 text-xs">
    <span class="rounded bg-ink-100 px-2 py-1 text-ink-700">{funcLabels[func] ?? func}</span>
    <span class="rounded bg-ink-100 px-2 py-1 text-ink-700 capitalize">{level}</span>
  </div>
</a>
